{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "program-config.json"
    }
  },
  "crons": [
    { "path": "/api/internal/retention", "schedule": "0 8 * * *" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/healthz", "destination": "/api" },
    { "source": "/readyz", "destination": "/api" },
    { "source": "/application-received", "destination": "/api" },
    { "source": "/programs", "destination": "/programs.html" },
    { "source": "/parents", "destination": "/parents.html" },
    { "source": "/team", "destination": "/team.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/delete", "destination": "/delete.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/safety", "destination": "/safety.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/admin",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }, { "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/admin.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }, { "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/delete.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }, { "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/privacy/delete",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }, { "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}
