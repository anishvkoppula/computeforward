# Runtime
NODE_ENV=development
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
TRUST_PROXY=0

# Production PostgreSQL. File storage is intentionally development-only.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_SIZE=10

# Generate independent secrets with: openssl rand -base64 48
ADMIN_TOKEN=replace-with-at-least-32-random-characters
IP_HASH_SECRET=replace-with-a-different-32-character-secret
CRON_SECRET=replace-with-a-third-independent-32-character-secret

# Transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=Compute Forward <no-reply@localhost>
ADMISSIONS_EMAILS=computeforward123@gmail.com

# Optional privacy-safe incident webhook
ALERT_WEBHOOK_URL=

# Request limits (defaults shown)
GLOBAL_RATE_LIMIT=200

# Abuse controls
APPLICATION_RATE_LIMIT=5
ADMIN_RATE_LIMIT=60
DELETION_RATE_LIMIT=3
